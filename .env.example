# Example .env file for UK Sabor Web
# Copy this to .env and replace with your real values

# Required to prevent Stripe from crashing on startup
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Database (PostgreSQL connection URL)
DATABASE_URL=postgresql://user:password@host:port/database

# JWT secret for sessions
JWT_SECRET=your_random_secret_key_here

# OAuth (leave empty to skip OAuth routes)
OAUTH_SERVER_URL=https://your-app.onrender.com

# Optional: Email (Resend API key - leave blank to disable emails)
# RESEND_API_KEY=

# ✅ BUNNY.NET VIDEO STREAMING - ÚNICA SOLUCIÓN DE ALMACENAMIENTO
# Obtén estas credenciales desde: https://dash.bunny.net/

# Tu API Key de Bunny.net (Dashboard → Stream → API)
BUNNY_API_KEY=your_bunny_api_key_here

# 📚 LIBRARY ID - REQUERIDO
# 1. Ve a https://dash.bunny.net/
# 2. Navega a Stream → Video Libraries
# 3. El número en la URL es tu Library ID
# Ejemplo: https://dash.bunny.net/stream/616736/library/overview → "616736"
BUNNY_VIDEO_LIBRARY_ID=616736

# 🔒 DOMAIN RESTRICTION (Recomendado para producción)
# Restringe la reproducción de videos solo a tu dominio oficial
BUNNY_ALLOWED_REFERRER=https://your-app.onrender.com

# ⚠️ NOTA IMPORTANTE:
# AWS S3 y Forge Storage han sido COMPLETAMENTE ELIMINADOS
# Todos los videos ahora usan Bunny.net Stream API
# NO necesitas configurar AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, etc.
